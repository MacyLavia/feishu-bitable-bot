# 飞书应用凭证（飞书开放平台 → 应用管理 → 凭证与基础信息）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SiliconFlow API Key（用于 AI 评分和 patch-cases 文本生成）
SILICONFLOW_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ai-model-pricing 平台地址（本地开发用 localhost，部署后改为 Vercel 地址）
PRICING_API_URL=http://localhost:3000
PRICING_API_KEY=coze_api_k3y_2026

# Dify 工作流凭据（Dify 工作流 → 访问 API → API Key）
# 推荐：开发团队维护的统一工作流，所有模型走这一个
DIFY_UNIFIED_KEY=app-xxxxxxxxxxxxxxxxxxxxx
# Legacy: dev_huang_* 三个独立工作流（收敛后可弃用，过渡期保留）
DIFY_IMAGE_KEY=app-xxxxxxxxxxxxxxxxxxxxx
DIFY_VIDEO_KEY=app-xxxxxxxxxxxxxxxxxxxxx
DIFY_TEXT_KEY=app-xxxxxxxxxxxxxxxxxxxxx
DIFY_HOST=43.160.192.41
